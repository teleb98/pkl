{
  "name": "pkl-webapp",
  "private": true,
  "version": "1.0.0",
  "description": "Personal Knowledge Library — AI 독서 앱",
  "author": "chiwon@gmail.com",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && node electron/launch.cjs\"",
    "electron:build": "cross-env ELECTRON=1 vite build && electron-builder --mac",
    "electron:build:win": "cross-env ELECTRON=1 vite build && electron-builder --win",
    "electron:build:linux": "cross-env ELECTRON=1 vite build && electron-builder --linux",
    "cap:sync": "vite build && cap sync",
    "cap:ios": "vite build && cap sync ios && cap open ios",
    "cap:android": "vite build && cap sync android && cap open android",
    "cap:run:ios": "vite build && cap sync ios && cap run ios",
    "cap:run:android": "vite build && cap sync android && cap run android",
    "cap:apk": "bash scripts/build-android.sh",
    "cap:apk:release": "bash scripts/build-android.sh release"
  },
  "build": {
    "appId": "com.pkl.app",
    "productName": "PKL — Personal Knowledge Library",
    "copyright": "Copyright © 2026 PKL",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/electron/**"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "scripts/notarize.cjs",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.0",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@mediapipe/tasks-genai": "^0.10.27",
    "@react-oauth/google": "^0.13.5",
    "cross-env": "^10.1.0",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.5"
  }
}
