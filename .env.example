# ── PKL 환경변수 예시 — 복사해서 .env 로 쓰세요 (.env 는 커밋 안 됨) ──

# [웹/공통] Google OAuth (웹 GIS)
VITE_GOOGLE_CLIENT_ID=

# [데스크톱] Electron Google OAuth (loopback) — docs/ELECTRON_OAUTH_SETUP.md
# VITE_GOOGLE_DESKTOP_CLIENT_ID=
# VITE_GOOGLE_DESKTOP_CLIENT_SECRET=

# ── macOS 공증 (둘 중 하나) — docs/MACOS_SIGNING.md ──
# 방법 A) keychain 프로파일 (권장, 평문 암호 없음): scripts/setup-notarize.sh 가 자동 추가
# APPLE_KEYCHAIN_PROFILE=pkl-notary
#
# 방법 B) Apple ID + 앱 암호
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=XXXXXXXXXX
